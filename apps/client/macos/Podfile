platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# whisper_kit declares macOS: ffiPlugin: true in pubspec.yaml but ships no
# macOS podspec. Place a stub podspec at the resolved pub-cache path of the
# symlink so CocoaPods can find it. Writing to the real path (not the symlink)
# ensures it survives Flutter's ephemeral directory recreation.
def ensure_whisper_kit_podspec
  podfile_dir = File.dirname(File.realpath(__FILE__))
  symlink = File.join(podfile_dir, 'Flutter', 'ephemeral', '.symlinks', 'plugins', 'whisper_kit')

  # If the symlink exists, resolve to its real target (pub cache).
  # Otherwise fall back to the symlink path itself (may not exist yet).
  real_plugin_dir = if File.symlink?(symlink)
                      File.expand_path(File.readlink(symlink), File.dirname(symlink))
                    else
                      symlink
                    end

  macos_dir = File.join(real_plugin_dir, 'macos')
  podspec_path = File.join(macos_dir, 'whisper_kit.podspec')

  return if File.exist?(podspec_path)

  FileUtils.mkdir_p(macos_dir)
  FileUtils.mkdir_p(File.join(macos_dir, 'Classes'))

  stub_src = File.join(podfile_dir, 'LocalPods', 'whisper_kit', 'whisper_kit.podspec')
  FileUtils.cp(stub_src, podspec_path)
end

ensure_whisper_kit_podspec

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end
end
